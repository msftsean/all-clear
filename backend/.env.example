# All Clear — backend environment template.  Copy to .env:   cp .env.example .env
#
# DEFAULT = MOCK MODE: the full pipeline runs offline with NO Azure credentials.
# Keep MOCK_MODE=true for labs 00-03 and any free, deterministic run.
# Set MOCK_MODE=false and fill in the Azure values only when you go live (labs 04+).
# When you run `azd up`, these values are provisioned and injected for you automatically.

# --- Run mode ---------------------------------------------------------------
MOCK_MODE=true
ENVIRONMENT=development

# --- Azure OpenAI (chat + embeddings) ---------------------------------------
# API key is optional. If omitted, managed identity / `az login` is used.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- Azure Cosmos DB (incident + session store) -----------------------------
# Variable names must match exactly. `azd up` creates database "frontdoor"
# with containers: incidents, sessions, audit_logs.
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=frontdoor

# --- Azure AI Search (knowledge base) ---------------------------------------
# After `azd up`, seed the index once:  python backend/scripts/seed_knowledge_base.py
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=knowledge-base

# --- Voice / Realtime (optional; works in mock mode) ------------------------
VOICE_ENABLED=true
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_REALTIME_API_VERSION=2025-08-28
REALTIME_VOICE=marin

# --- Phone / ACS (coach-led demo only; leave disabled as a participant) ------
PHONE_ENABLED=false
# AZURE_ACS_ENDPOINT=
# ACS_PHONE_NUMBER=+15551234567
