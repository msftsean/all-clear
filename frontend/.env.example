# Frontend Environment Configuration
# Copy this file to .env:   cp .env.example .env
#
# IMPORTANT: leave VITE_API_BASE_URL EMPTY. The Vite dev server proxies /api to the
# backend (see vite.config.ts). Setting it to http://localhost:8000 BREAKS the app in
# GitHub Codespaces because the browser cannot reach the container's localhost.

# API Configuration
VITE_API_BASE_URL=
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_MOCK_MODE=true
VITE_ENABLE_HIGH_CONTRAST=false

# Session Configuration
VITE_SESSION_TIMEOUT_MINUTES=30

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ENDPOINT=
